<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <!-- promote selected MDC keys to top-level JSON fields -->
            <includeMdcKeyName>eventId</includeMdcKeyName>
            <includeMdcKeyName>jobType</includeMdcKeyName>
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <includeMdcKeyName>spanId</includeMdcKeyName>
        </encoder>
    </appender>

    <!-- default: INFO root, suppress noisy Spring Kafka internal logs -->
    <springProfile name="!test">
        <root level="INFO">
            <appender-ref ref="JSON"/>
        </root>
        <logger name="io.batchintel" level="INFO"/>
        <logger name="org.springframework.kafka" level="WARN"/>
    </springProfile>

    <!-- test: quiet root so test output is readable -->
    <springProfile name="test">
        <root level="WARN">
            <appender-ref ref="JSON"/>
        </root>
        <logger name="io.batchintel" level="DEBUG"/>
    </springProfile>

</configuration>
